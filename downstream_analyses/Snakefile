		duplication_sizes_non_hyper="3_sv_distribution_by_region/hyperdivergent/sv_sizes/ALL_STRAINS_DUP-nonhyperdivergent_sizes.txt",
		inversion_sizes_hyper="3_sv_distribution_by_region/hyperdivergent/sv_sizes/ALL_STRAINS_INV-hyperdivergent_sizes.txt",
		inversion_sizes_non_hyper="3_sv_distribution_by_region/hyperdivergent/sv_sizes/ALL_STRAINS_INV-nonhyperdivergent_sizes.txt",		
