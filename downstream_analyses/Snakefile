# Run VEP to get consequences 		
rule run_vep:
	input:
		"1_vcfs_beds_filtered/{svtype}-no_homozygous_reference.vcf"
	output:
		"4_vep/{svtype}-vep.vcf"
	conda:  "yaml/vep.yaml"
	shell:
		"""
			vep --cache --format vcf --input_file {input} --output_file {output} --species caenorhabditis_elegans --vcf
		"""

