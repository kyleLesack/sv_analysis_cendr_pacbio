# Get overlap between SVs and transposons
rule get_transposon_overlap:
	input:
			"1_vcfs_beds_filtered/per_strain/{strain}_{svtype}-no_homozygous_reference.bed",
			"3_sv_distribution_by_region/transposons/{strain}_transposons.bed"
	output:
			"3_sv_distribution_by_region/transposons/overlap/{strain}_{svtype}.txt"
	conda:  "yaml/bedtools.yaml"
	shell:
		"""
			bedtools intersect -wa -wb -a 3_sv_distribution_by_region/transposons/{wildcards.strain}_transposons.bed -b 1_vcfs_beds_filtered/per_strain/{wildcards.strain}_{wildcards.svtype}-no_homozygous_reference.bed | sort -k1,1 -k2,2n > 3_sv_distribution_by_region/transposons/overlap/{wildcards.strain}_{wildcards.svtype}.txt
		"""

# Get distribution of SVs among chromosome arms and centers
rule get_distribution_arms_centers:
	input:
		coordinates="0_input_data/reference/chr_arms_centers.bed",
		bed="1_vcfs_beds_filtered/{svtype}-no_homozygous_reference.bed"
	output:
		bed="3_sv_distribution_by_region/chr_arms_centers/{svtype}_chr_arms_centers.bed",
		txt="3_sv_distribution_by_region/chr_arms_centers/{svtype}_chr_arms_centers.txt"
	conda:  "yaml/bedtools.yaml"
	shell:
		"""
			bedtools intersect -wa -wb -a  {input.coordinates} -b {input.bed} | sort -k1,1 -k2,2n > {output.bed}
			bedtools intersect -C -a {input.coordinates} -b {input.bed} > {output.txt}

		"""

# Summarize the distribution of SVs in the arms in a table
rule summarize_arms_centers_table:
	input:
		deletion_distribution="3_sv_distribution_by_region/chr_arms_centers/DEL_chr_arms_centers.txt",
		duplication_distribution="3_sv_distribution_by_region/chr_arms_centers/DUP_chr_arms_centers.txt",
		inversion_distribution="3_sv_distribution_by_region/chr_arms_centers/INV_chr_arms_centers.txt"
	output:
		"3_sv_distribution_by_region/chr_arms_centers/SV_table_chr_arms_centers.csv"
	conda:  "yaml/r_packages.yaml"		
	script:
		"scripts/summarize_arm_center_table.R"


# Get distribution of SVs among chromosome domains
rule get_distribution_chr_domains:
	input:
		coordinates="0_input_data/reference/chr_domains_converted2bp.bed",
		bed="1_vcfs_beds_filtered/{svtype}-no_homozygous_reference.bed"
	output:
		bed="3_sv_distribution_by_region/chr_domains/{svtype}_chr_domains.bed",
		txt="3_sv_distribution_by_region/chr_domains/{svtype}_chr_domains.txt"
	conda:  "yaml/bedtools.yaml"
	shell:
		"""
			bedtools intersect -wa -wb -a  {input.coordinates} -b {input.bed} | sort -k1,1 -k2,2n > {output.bed}
			bedtools intersect -C -a {input.coordinates} -b {input.bed} > {output.txt}
		"""

# Summarize the distribution of SVs in the chr domains in a table
