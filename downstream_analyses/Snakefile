ALL_STRAINS = ['DL238', 'ECA36', 'ECA396', 'EG4725', 'JU1400', 'JU2526', 'JU2600', 'JU310', 'MY2147', 'MY2693', 'NIC2', 'NIC526', 'QX1794', 'XZ1516']
TRANSPOSON_STRAINS = ['DL238', 'ECA36', 'EG4725', 'JU1400', 'JU2526', 'JU310', 'NIC2', 'QX1794']
SVTYPES = ['DEL', 'DUP', 'INV']
VEP_IMPACT_TYPES = ["HIGH", "MODERATE", "LOW", "MODIFIER"]
GENE_CATEGORIES = ["protein_coding_genes", "ncRNA_genes", "pseudogenes"]
GENE_FAMILIES = ["clec", "cyp", "fbox", "gpcrs", "gst", "nhr", "ugt"]

# snakemake --use-conda -n --cores 1 # Dry run
# snakemake -n all --delete-all-output # Delete files created by Snakemake
# snakemake -p -n --use-conda --cores 1 # Show the commands it will run. Useful to troubleshoot shell commands

rule all:
	input:
		"0_input_data/reference/c_elegans.WBcel235.all_genes.bed",
		expand("0_input_data/reference/gene_types/{genetype}.txt", genetype = ["protein_coding_genes", "pseudogenes", "ncRNA_genes"]),
		expand("1_vcfs_beds_filtered/{svtype}-no_homozygous_reference.{extension}", svtype = SVTYPES, extension=["vcf", "bed"]),
		expand("1_vcfs_beds_filtered/per_strain/{strain}_{svtype}-no_homozygous_reference.bed", strain = ALL_STRAINS, svtype = SVTYPES),
		"2_basic_sv_stats/sv_size_summary.csv",
		expand("2_basic_sv_stats/overlapping_svs_same_strain/{strain}_{comparison}_overlap.bed", strain = ALL_STRAINS, comparison = ["del_dup", "del_inv", "dup_inv"]),
		expand("2_basic_sv_stats/overlapped_genes/{svtype}_{genecategory}.bed", svtype = SVTYPES, genecategory = GENE_CATEGORIES), 
		expand("2_basic_sv_stats/svs_overlapping_multiple_genes/{svtype}_{genecategory}.bed", svtype = SVTYPES, genecategory = GENE_CATEGORIES),
		expand("2_basic_sv_stats/singletons/{svtype}_{suffix}", svtype = SVTYPES, suffix=["singletons.csv", "all_strains.txt"]),
		expand("2_basic_sv_stats/allele_frequencies/{svtype}_allele_frequencies.csv", svtype = SVTYPES),
		expand("3_sv_distribution_by_region/transposons/{strain}_transposons.bed", strain = TRANSPOSON_STRAINS),
		expand("3_sv_distribution_by_region/transposons/overlap/{strain}_{svtype}.txt", strain = TRANSPOSON_STRAINS, svtype = SVTYPES),
		expand("3_sv_distribution_by_region/chr_arms_centers/{svtype}_chr_arms_centers.{extension}", svtype = SVTYPES, extension=["bed", "txt"]),
		"3_sv_distribution_by_region/chr_arms_centers/SV_table_chr_arms_centers.csv",
		expand("3_sv_distribution_by_region/chr_domains/{svtype}_chr_domains.{extension}", svtype = SVTYPES, extension=["bed", "txt"]),
		"3_sv_distribution_by_region/chr_domains/SV_table_chr_domains.csv",
		expand("0_input_data/reference/hyperdivergent/{strain}_hyperdivergent.bed", strain = ALL_STRAINS),
		expand("3_sv_distribution_by_region/hyperdivergent/{strain}_{svtype}-hyperdivergent.{extension}", strain = ALL_STRAINS, svtype = SVTYPES, extension=["bed", "counts"]),
		expand("3_sv_distribution_by_region/hyperdivergent/ALL_STRAINS_{svtype}-hyperdivergent.{extension}", svtype = SVTYPES, extension=["bed", "counts"]),
		expand("3_sv_distribution_by_region/hyperdivergent/sv_sizes/ALL_STRAINS_{svtype}-{region}_sizes.txt", svtype = SVTYPES, region=["hyperdivergent", "nonhyperdivergent"]),
		"3_sv_distribution_by_region/hyperdivergent/sv_sizes/ALL_STRAINS_sizes.csv",
		expand("4_vep/{svtype}-vep.vcf", svtype = SVTYPES),
		expand("4_vep/high_impact_svs/{svtype}-high_impact_svs.txt", svtype = SVTYPES),
		expand("4_vep/genes_of_interest/{svtype}.tsv", svtype = ["DEL", "DUP"]),
		expand("4_vep/genes_of_interest/{svtype}.entrez.tsv", svtype = ["DEL", "DUP"]),
		expand("4_vep/genes_of_interest/{svtype}_overlap_prop.tsv", svtype = ["DEL", "DUP"]),
		expand("4_vep/gene_families/{svtype}-{family}.txt", svtype = ["DEL", "DUP"], family =  GENE_FAMILIES),
		expand("4_vep/gene_families/ALLSVS-{family}.txt", family = GENE_FAMILIES),
		expand("4_vep/predicted_consequences/{svtype}-impact_consequence_summary.csv", svtype = SVTYPES),
		expand("5_wormcat_ora/gene_families/{family}/summary.txt", family = GENE_FAMILIES),
		expand("5_wormcat_ora/plots/wormcat_c1-c3.{extension}", extension = ["png", "eps"])
		
		
# Get list of protein coding, ncRNA, and pseudogenes from gff3 file
rule get_gene_types:
	input:
		"0_input_data/reference/Caenorhabditis_elegans.WBcel235.61.gff3"
	output:
		"0_input_data/reference/gene_types/{genetype}.txt"
	params:
		ofs_delim=r'"\t"',
		reference="0_input_data/reference/Caenorhabditis_elegans.WBcel235.61.gff3"
	shell:
		"""
			awk 'BEGIN {{OFS = {params.ofs_delim}}};$3=="gene"{{print $1,$4-1,$5,$9}}' {params.reference} | cut -d ":" -f 2 | cut -d ";" -f 1 | sort > 0_input_data/reference/gene_types/protein_coding_genes.txt
			awk 'BEGIN {{OFS = {params.ofs_delim}}};$3=="ncRNA_gene"{{print $1,$4-1,$5,$9}}' {params.reference} | cut -d ":" -f 2 | cut -d ";" -f 1 | sort > 0_input_data/reference/gene_types/ncRNA_genes.txt
			awk 'BEGIN {{OFS = {params.ofs_delim}}};$3=="pseudogene"{{print $1,$4-1,$5,$9}}' {params.reference} | grep "biotype=pseudogene" | cut -d ":" -f 2 | cut -d ";" -f 1 | sort > 0_input_data/reference/gene_types/pseudogenes.txt
		"""

# Create BED files that only contain single types of genes
rule create_c_elegans_gene_bedfile:
	input:
		"0_input_data/reference/Caenorhabditis_elegans.WBcel235.61.gff3"
	output:
		ncRNA="0_input_data/reference/c_elegans.WBcel235.ncRNA_genes.bed",
		protein="0_input_data/reference/c_elegans.WBcel235.protein_coding_genes.bed",
		pseudogene="0_input_data/reference/c_elegans.WBcel235.pseudogenes.bed",
		all_genes="0_input_data/reference/c_elegans.WBcel235.all_genes.bed"
	params:
		ofs_delim=r'"\t"'
	shell:
		"""
			awk 'BEGIN {{OFS = {params.ofs_delim}}};$3=="gene"{{print $1,$4-1,$5,$9}}' {input} | grep "biotype=protein" | cut -d ";" -f 1 | sed -e 's/ID=gene://g' > {output.protein}
			awk 'BEGIN {{OFS = {params.ofs_delim}}};$3=="ncRNA_gene"{{print $1,$4-1,$5,$9}}' {input} | cut -d ";" -f 1 | sed -e 's/ID=gene://g' > {output.ncRNA}
			awk 'BEGIN {{OFS = {params.ofs_delim}}};$3=="pseudogene"{{print $1,$4-1,$5,$9}}' {input} | cut -d ";" -f 1 | sed -e 's/ID=gene://g' > {output.pseudogene}
			cat {output.ncRNA} {output.protein} {output.pseudogene} | sort -k1,1 -k2,2n > {output.all_genes}
		"""

# Remove SV calls that are only present in strains genotyped as being homozygous for the reference allele
rule filter_homozygous_reference:
	input:
		"0_input_data/vcfs/{svtype}.vcf"
	output:
		"1_vcfs_beds_filtered/{svtype}-no_homozygous_reference.vcf"
	params:
		bad_sv_call="7_0_Sniffles2.INV.859ES1" # Has a homozygous reference call and another that is genotyped as ./. but still included as true call
	script:
		"scripts/filter_homozygous_reference.py"

# Convert filtered VCF files to BED format		
rule convertvcf2bed:
	input:
			"1_vcfs_beds_filtered/{svtype}-no_homozygous_reference.vcf"
	output:
	        "1_vcfs_beds_filtered/{svtype}-no_homozygous_reference.bed"
	script:
		"scripts/convert_vcf_to_bed.py"

# Create BED per strain
