# Get hyperdivergent regions per strain
rule gene_hyperdivergent_regions_per_strain:
	input:
		"0_input_data/reference/20250625_c_elegans_divergent_regions_strain.bed"
	output:
		"0_input_data/reference/hyperdivergent/{strain}_hyperdivergent.bed"
	shell:
		"""
			grep -w {wildcards.strain} {input} > {output}
		"""

# Find SVs that overlap with hyperdivergent regions		
rule get_distribution_hyperdivergent:
	input:
		coordinates="0_input_data/reference/hyperdivergent/{strain}_hyperdivergent.bed",
		bedfile="1_vcfs_beds_filtered/per_strain/{strain}_{svtype}-no_homozygous_reference.bed"
	output:
		bedfile="3_sv_distribution_by_region/hyperdivergent/{strain}_{svtype}-hyperdivergent.bed",
		count_per_region="3_sv_distribution_by_region/hyperdivergent/{strain}_{svtype}-hyperdivergent.counts"
	params:
		ofs_delim=r'"\t"'		
	conda:  "yaml/bedtools.yaml"
	shell:
		"""
			bedtools intersect -wb -a {input.coordinates} -b {input.bedfile} | sort -k1,1 -k2,2n | cut -f 1-4,8 | awk 'BEGIN {{OFS = {params.ofs_delim}}}{{print $1,$2,$3,$5,$4}}' > {output.bedfile}
			bedtools intersect -C -a {input.coordinates}  -b {input.bedfile} > {output.count_per_region}
		"""
		
# Combine hyperdivergent overlap results from all strains into single file for each SV type
rule combine_hyperdivergent:
	input:
		bedfiles=expand("3_sv_distribution_by_region/hyperdivergent/{strain}_{svtype}-hyperdivergent.bed", strain = ALL_STRAINS, allow_missing = True),
		countfiles=expand("3_sv_distribution_by_region/hyperdivergent/{strain}_{svtype}-hyperdivergent.counts", strain = ALL_STRAINS, allow_missing = True)
	output:
		bedfile="3_sv_distribution_by_region/hyperdivergent/ALL_STRAINS_{svtype}-hyperdivergent.bed",
		countfile="3_sv_distribution_by_region/hyperdivergent/ALL_STRAINS_{svtype}-hyperdivergent.counts"
	shell:
		"""
			cat {input.bedfiles} > {output.bedfile}
			cat {input.countfiles} > {output.countfile}
		"""

# Get the sizes of SVs inside and outside of hyperdivergent regions
# Validated with: comm -12 <(sort 3_sv_distribution_by_region/hyperdivergent/sv_sizes/ALL_STRAINS_DEL-hyperdivergent_sizes.txt) <(sort 3_sv_distribution_by_region/hyperdivergent/sv_sizes/ALL_STRAINS_DEL-nonhyperdivergent_sizes.txt)
rule get_hyperdivergent_sizes:
	input:
		bedfile="3_sv_distribution_by_region/hyperdivergent/ALL_STRAINS_{svtype}-hyperdivergent.bed",
		vcffile="1_vcfs_beds_filtered/{svtype}-no_homozygous_reference.vcf"
	output:
		hyperfile="3_sv_distribution_by_region/hyperdivergent/sv_sizes/ALL_STRAINS_{svtype}-hyperdivergent_sizes.txt",
		nonhyperfile="3_sv_distribution_by_region/hyperdivergent/sv_sizes/ALL_STRAINS_{svtype}-nonhyperdivergent_sizes.txt"
	script:
		"scripts/get_sv_sizes_hyperdivergent.py" 

