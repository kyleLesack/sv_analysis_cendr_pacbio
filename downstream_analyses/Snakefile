# Get Entrez gene symbols for SVs spanning genes of interest
rule get_entrez_symbols_for_genes_of_interest:
	input: 
		"4_vep/genes_of_interest/{svtype}.tsv",
		"4_vep/{svtype}-vep.vcf"
	output:
		"4_vep/genes_of_interest/{svtype}.entrez.tsv"
	conda:  "yaml/r_packages.yaml"
	script:
		"scripts/get_entrez_gene_names.R"
	
# Get overlap proportion for SVs spanning genes of interest
rule get_overlap_proportion_for_genes_of_interest:
	input: 
		"2_basic_sv_stats/overlapped_genes/{svtype}_protein_coding_genes.bed",
		"4_vep/genes_of_interest/{svtype}.entrez.tsv" 
	output:
		"4_vep/genes_of_interest/{svtype}_overlap_prop.tsv"
	conda:  "yaml/r_packages.yaml"
	script:
		"scripts/get_overlap_prop.R"

# Get gene family members with SVs
rule get_gene_family_members:
	input:
		vcf="4_vep/predicted_consequences/{svtype}-HIGH-protein_coding_genes.txt",
		family="0_input_data/reference/gene_families/{family}/genes_and_candidates.tsv"
	output:
		"4_vep/gene_families/{svtype}-{family}.txt"
	shell:
		"""
			grep -Ff 4_vep/predicted_consequences/{wildcards.svtype}-HIGH-protein_coding_genes.txt 0_input_data/reference/gene_families/{wildcards.family}/genes_and_candidates.tsv | cut -d ":" -f 2 | cut -d ";" -f 1,2 | sed -e 's/Name=//g' | tr ";" "," | sed -e 's/$/,{wildcards.svtype}/' > {output}|| true
		"""


# Concatenate gene family membership
rule concatenate_gene_family_members:
	input:
		expand("4_vep/gene_families/{svtype}-{family}.txt", svtype = ["DEL", "DUP"], allow_missing = True)
	output:
		"4_vep/gene_families/ALLSVS-{family}.txt"
	shell:
		"""
			cat {input} > {output}
		"""
# Summarize gene family membership in WormCat categories
rule summarize_gene_family_members_wormcat:
	input:
		"4_vep/gene_families/ALLSVS-{genefamily}.txt"
	output:
		"5_wormcat_ora/gene_families/{genefamily}/summary.txt",
		"5_wormcat_ora/gene_families/{genefamily}/wbgenes.txt"
	params:
		wormcatfile="5_wormcat_ora/WormCat_level1_no_pseudogenes.csv"
	shell:
		"""
			bash scripts/summarize_gene_families_wormcat.sh {wildcards.genefamily} {input} {params.wormcatfile}
		"""

# Plot wormcat results
rule plot_wormcat:
	input:
		cat1 = "5_wormcat_ora/WormCat_level1_no_pseudogenes.csv",
		cat2 = "5_wormcat_ora/WormCat_level2_no_pseudogenes.csv",
		cat3 = "5_wormcat_ora/WormCat_level3_no_pseudogenes.csv"
	output:
		expand("5_wormcat_ora/plots/wormcat_c1-c3.{extension}", extension = ["png", "eps"])
	conda:  "yaml/r_packages.yaml"		
	script:
		"scripts/plot_wormcat_results.R"
