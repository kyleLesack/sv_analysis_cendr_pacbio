# Get SVs of different types that overlap in same strain
rule get_overlapping_svs_same_strain:
	input:
		deletion_bed="1_vcfs_beds_filtered/per_strain/{strain}_DEL-no_homozygous_reference.bed",
		duplication_bed="1_vcfs_beds_filtered/per_strain/{strain}_DUP-no_homozygous_reference.bed",
		inversion_bed="1_vcfs_beds_filtered/per_strain/{strain}_INV-no_homozygous_reference.bed"
	output:
		del_dup_overlap="2_basic_sv_stats/overlapping_svs_same_strain/{strain}_del_dup_overlap.bed",
		del_inv_overlap="2_basic_sv_stats/overlapping_svs_same_strain/{strain}_del_inv_overlap.bed",
		dup_inv_overlap="2_basic_sv_stats/overlapping_svs_same_strain/{strain}_dup_inv_overlap.bed"
	conda:  "yaml/bedtools.yaml"
	shell:
		"""
			bedtools intersect -wo -a {input.deletion_bed} -b {input.duplication_bed} | sort -k1,1 -k2,2n | cut -f 1-4,6-9 > {output.del_dup_overlap}
			bedtools intersect -wo -a {input.deletion_bed} -b {input.inversion_bed} | sort -k1,1 -k2,2n | cut -f 1-4,6-9 > {output.del_inv_overlap}
			bedtools intersect -wo -a {input.duplication_bed} -b {input.inversion_bed} | sort -k1,1 -k2,2n | cut -f 1-4,6-9 > {output.dup_inv_overlap}
		"""

# Get genes that are overlapped by SVs
